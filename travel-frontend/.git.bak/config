[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
	ignorecase = true
	precomposeunicode = true
[remote "origin"]
	url = https://github.com/vinhvinh450/travel-frontend.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[branch "Quang_DEV"]
	remote = origin
	merge = refs/heads/Quang_DEV
	vscode-merge-base = origin/Quang_DEV
[branch "Dev"]
	remote = origin
	merge = refs/heads/Dev
	vscode-merge-base = origin/Dev
